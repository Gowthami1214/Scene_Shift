# SceneShift Environment Configuration
# Copy this file to .env and fill in your values

# ── Device Configuration ───────────────────────────────────────────────────────
# Set to 1 to force CPU even if GPU is available (useful for debugging)
SCENESHIFT_FORCE_CPU=0

# ── Hugging Face ───────────────────────────────────────────────────────────────
# Optional: your HF token for private/gated models
# HUGGING_FACE_HUB_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx

# Model cache directory (defaults to ~/.cache/huggingface)
# HF_HOME=/path/to/model/cache

# ── SD Models ─────────────────────────────────────────────────────────────────
# Inpainting model (default: runwayml/stable-diffusion-inpainting)
# SD_INPAINTING_MODEL=runwayml/stable-diffusion-inpainting

# Background generation model (default: runwayml/stable-diffusion-v1-5)
# SD_BACKGROUND_MODEL=runwayml/stable-diffusion-v1-5

# ── Server Configuration ───────────────────────────────────────────────────────
GRADIO_PORT=7860
FASTAPI_PORT=8000
FASTAPI_HOST=0.0.0.0

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── AWS Deployment (optional) ─────────────────────────────────────────────────
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=sceneshift-outputs
